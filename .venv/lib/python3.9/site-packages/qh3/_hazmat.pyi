class UdpSocketState:
    """UDP socket state backed by quinn-udp for fast batched syscalls.

    On Linux uses recvmmsg/sendmsg with GRO/GSO.
    On macOS uses recvmsg_x/sendmsg_x (Apple private batch APIs).
    Only available on Unix platforms.
    """

    def __init__(self, fd: int) -> None: ...
    @property
    def max_gso_segments(self) -> int: ...
    @property
    def gro_segments(self) -> int: ...
    @property
    def may_fragment(self) -> bool: ...
    def recv(
        self,
    ) -> tuple[list[bytes], tuple[str, int] | tuple[str, int, int, int] | None]: ...
    def send(self, datagrams: list[bytes], addr_ip: str, addr_port: int) -> int: ...
